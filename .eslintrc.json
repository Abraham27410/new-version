{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": ["eslint:recommended", "plugin:prettier/recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["prettier"],
  "rules": {
    "prettier/prettier": "error",
    "eqeqeq": "error",
    "no-console": "warn",
    "no-unused-vars": "warn",
    "no-undef": "error"
  },
  "ignorePatterns": ["calculator/assets/js/bootstrap.min.js"],
  "globals": {
    "module": "readonly"
  }
}